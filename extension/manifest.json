{
  "manifest_version": 3,
  "name": "Emma",
  "version": "1.0.0",

  "permissions": [
    "storage"
  ],

  "host_permissions": [
    "https://chatgpt.com/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*"
      ],
      "js": [
        "core/EmmaEvent.js",
        "core/EmmaEventBus.js",
        "core/EmmaRuntime.js",
        "adapters/chatgpt/ChatGPTAdapter.js",
        "content/content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}