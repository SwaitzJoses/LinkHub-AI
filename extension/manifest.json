{
  "manifest_version": 3,
  "name": "Emma",
  "version": "0.1.0",
  "description": "Emma Personal Intelligence",

  "permissions": [
    "storage",
    "activeTab"
  ],

  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://claude.ai/*",
    "https://gemini.google.com/*",
    "https://grok.com/*",
    "https://chat.deepseek.com/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*",
        "https://grok.com/*",
        "https://chat.deepseek.com/*"
      ],
      "js": [
        "content.js"
      ]
    }
  ]
}